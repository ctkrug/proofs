# Proof Factory shared non-secret configuration.
# Installed as /etc/proof-factory/proof-factory.env by scripts/install-box.sh.
# Credentials belong only in the existing service-scoped credential file.

PROOF_FACTORY_ROOT=/root/proof-factory
PROOF_FACTORY_CACHE_DIR=/root/.cache/proof-factory
PROOF_USAGE_CACHE_PATH=/root/project-factory/state/usage_cache.json
CODEX_BIN=/root/.local/bin/codex

# Model-backed passes are bounded independently of checkpointed lab jobs.
PROOF_EASY_TIMEOUT_SEC=3600
PROOF_HARD_TIMEOUT_SEC=7200
PROOF_EASY_DELEGATE_TIMEOUT_SEC=600
PROOF_HARD_DELEGATE_TIMEOUT_SEC=1200
PROOF_JSON_REPAIR_TIMEOUT_SEC=180
PROOF_SCOUT_TIMEOUT_SEC=3600
PROOF_STRATEGY_TIMEOUT_SEC=3600
PROOF_EASY_EXPECTED=true

# Keep the verified single-core Lean setup and its immutable shared cache.
ELAN_HOME=/root/.cache/proof-factory/lean/elan
LEAN_NUM_THREADS=1
PROOF_FACTORY_FORMAL_CONJECTURES_REVISION=b8b5208aa5d01f5f91c49ca516bf09cae8d93693
PROOF_FACTORY_FORMAL_CONJECTURES_MANIFEST_SHA256=5b99b5f4f807cbba67bbcd22e5e486c17d6a8d970ea218de08d05830ab350c26
PROOF_FACTORY_LEAN_BOOTSTRAP_MIN_FREE_KIB=8388608

# Public repository policy.
PROOF_REPO_GITHUB_OWNER=ctkrug
PROOF_REPO_GIT_NAME=ctkrug
PROOF_REPO_GIT_EMAIL=ctkrug4501@gmail.com
PROOF_REPO_MAX_FILE_BYTES=52428800

# Optional observability; PHOENIX_API_KEY remains in the credential file.
PHOENIX_ENABLED=true
PHOENIX_ENDPOINT=https://app.phoenix.arize.com/s/ctkrug4501
PHOENIX_PROJECT=proof-factory
PHOENIX_CAPTURE_TEXT=true
PHOENIX_TEXT_LIMIT=6000

# Public Cloudflare KV namespace; account and API token remain credentials.
PROOF_RUNTIME_KV_NAMESPACE_ID=4e48b416e03447ac87c86a60c12a3bc4
