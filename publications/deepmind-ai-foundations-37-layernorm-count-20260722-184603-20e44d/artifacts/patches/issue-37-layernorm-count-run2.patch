+"""Regression tests for the Course 4 parameter-count references."""
+
+import ast
+import json
+from pathlib import Path
+import runpy
+import unittest
+
+
+_PROJECT_ROOT = Path(__file__).resolve().parents[4]
+_NOTEBOOK = (
+    _PROJECT_ROOT
+    / "course_4/gdm_lab_4_5_reflection_on_trainable_parameters.ipynb"
+)
+_REFERENCE_IMPLEMENTATION = Path(__file__).with_name(
+    "reference_implementations.py"
+)
+_FUNCTION_NAMES = (
+    "parameter_count_layer_norm",
+    "parameter_count_attention",
+    "parameter_count_mlp",
+    "parameter_count_transformer_block",
+)
+_TEST_HYPERPARAMETERS = (
+    {"embedding_dim": 1, "mlp_dim": 1},
+    {"embedding_dim": 128, "mlp_dim": 512},
+    {"embedding_dim": 256, "mlp_dim": 384},
+)
+
+
+def _notebook_reference_functions() -> dict[str, object]:
+  """Loads only the typed reference-solution functions from the notebook."""
+  cells = json.loads(_NOTEBOOK.read_text(encoding="utf-8"))["cells"]
+  namespace = {}
+  for name in _FUNCTION_NAMES:
+    marker = f"def {name}(hyperparams: dict[str, int])"
+    matches = []
+    for cell in cells:
+      source = "".join(cell.get("source", []))
+      if (
+          cell.get("cell_type") == "code"
+          and marker in source
+          and "parameter_count = ..." not in source
+      ):
+        matches.append(source)
+    if len(matches) != 1:
+      raise AssertionError(
+          f"expected one typed notebook reference for {name}, "
+          f"found {len(matches)}"
+      )
+
+    function_nodes = [
+        node
+        for node in ast.parse(matches[0]).body
+        if isinstance(node, ast.FunctionDef) and node.name == name
+    ]
+    if len(function_nodes) != 1:
+      raise AssertionError(f"expected one function definition for {name}")
+    module = ast.Module(body=function_nodes, type_ignores=[])
+    exec(
+        compile(ast.fix_missing_locations(module), str(_NOTEBOOK), "exec"),
+        namespace,
+    )
+  return namespace
+
+
+class ReferenceImplementationsTest(unittest.TestCase):
+
+  def test_transformer_block_counts_two_complete_layer_norms(self):
+    references = {
+        "packaged feedback": runpy.run_path(str(_REFERENCE_IMPLEMENTATION)),
+        "notebook": _notebook_reference_functions(),
+    }
+    for label, namespace in references.items():
+      for hyperparams in _TEST_HYPERPARAMETERS:
+        with self.subTest(reference=label, hyperparams=hyperparams):
+          embedding_dim = hyperparams["embedding_dim"]
+          mlp_dim = hyperparams["mlp_dim"]
+          layer_norm = 2 * embedding_dim  # gamma and beta vectors.
+          attention = 4 * (embedding_dim + 1) * embedding_dim
+          mlp = (embedding_dim + 1) * mlp_dim + (mlp_dim + 1) * embedding_dim
+
+          self.assertEqual(
+              namespace["parameter_count_layer_norm"](hyperparams), layer_norm
+          )
+          self.assertEqual(
+              namespace["parameter_count_transformer_block"](hyperparams),
+              attention + mlp + 2 * layer_norm,
+          )
+
+
+if __name__ == "__main__":
+  unittest.main()
