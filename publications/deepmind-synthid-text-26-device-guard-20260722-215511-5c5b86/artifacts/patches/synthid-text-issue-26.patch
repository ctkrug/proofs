+import types
+
+from absl.testing import absltest
+from absl.testing import parameterized
+import mock
+
+from synthid_text import detector_bayesian
+
+
+class BayesianDetectorDeviceGuardTest(parameterized.TestCase):
+
+  def test_cpu_rejected_before_processing(self):
+    with mock.patch.object(
+        detector_bayesian.BayesianDetector, "process_raw_model_outputs"
+    ) as process:
+      with self.assertRaisesRegex(ValueError, "unstable on CPUs"):
+        detector_bayesian.BayesianDetector.train_best_detector(
+            tokenized_wm_outputs=[],
+            tokenized_uwm_outputs=[],
+            logits_processor=None,
+            tokenizer=None,
+            torch_device=types.SimpleNamespace(type="cpu"),
+        )
+
+    process.assert_not_called()
+
+  @parameterized.parameters("cuda", "tpu")
+  def test_accelerator_type_reaches_training_pipeline(self, device_type):
+    processed = (
+        "train_g_values",
+        "train_masks",
+        "train_labels",
+        "cv_g_values",
+        "cv_masks",
+        "cv_labels",
+    )
+    expected = (object(), 0.0)
+    with mock.patch.object(
+        detector_bayesian.BayesianDetector,
+        "process_raw_model_outputs",
+        return_value=processed,
+    ) as process:
+      with mock.patch.object(
+          detector_bayesian.BayesianDetector,
+          "train_best_detector_given_g_values",
+          return_value=expected,
+      ) as train:
+        actual = detector_bayesian.BayesianDetector.train_best_detector(
+            tokenized_wm_outputs=[],
+            tokenized_uwm_outputs=[],
+            logits_processor=None,
+            tokenizer=None,
+            torch_device=types.SimpleNamespace(type=device_type),
+        )
+
+    self.assertIs(actual, expected)
+    self.assertEqual(process.call_args.kwargs["torch_device"].type, device_type)
+    train.assert_called_once()
+
+
+if __name__ == "__main__":
+  absltest.main()
